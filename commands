#dorado

# basecalling and flagging barcodes
dorado basecaller dna_r10.4.1_e8.2_400bps_hac@v4.3.0 pod5/ --kit-name SQK-RBK114-24 > raw_calls.bam

# demultiplex into individual fastq files
dorado demux --no-classify --output-dir demuxed_fastq/ --emit-fastq raw_calls.bam

# nanoplot & chopper

mkdir -p nanoplot_unfiltered/
for fastq in demuxed_fastq/*.fastq; do
    [ "$fastq" == "demuxed_fastq/unclassified.fastq" ] && continue
    sample=$(basename "$fastq" .fastq)
    NanoPlot --fastq "$fastq" --outdir "nanoplot_before/${sample}" \
             --prefix "${sample}_before_" --plots dot --loglength --threads 4
done

mkdir -p filtered_fastq/
for fastq in demuxed_fastq/*.fastq; do
    [ "$fastq" == "demuxed_fastq/unclassified.fastq" ] && continue
    sample=$(basename "$fastq" .fastq)
    chopper -q 10 -l 500 -i "$fastq" > "filtered_fastq/filtered_${sample}.fastq"
done
# repeat nanoplot step

# kraken2 for k-mer mapping
